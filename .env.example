# Firebase – copy to .env and fill with your Firebase project values
# Get these from: Firebase Console → Project Settings → General → Your apps

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# OAuth 2.0 Web client ID (required for Google Sign-In in the Android/iOS app).
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → Web client
# (often named "Web client (auto created by Google Service)"). Same project as Firebase.
# Must match the Web client used by Firebase Auth. Required for native Google Sign-In (APK/iOS).
# Missing SHA-1 for your Android app in Firebase causes ApiException 10 (DEVELOPER_ERROR) — see BACKEND_SETUP.md.
VITE_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# OpenRouter: Capacitor WebViews use https://localhost — set a real URL if your API key is origin-restricted.
# VITE_APP_PUBLIC_URL=https://your-production-site.example
# VITE_OPENROUTER_HTTP_REFERER=https://your-production-site.example

# Cloud Functions base URL (required for voice transcription via transcribeWhisper, getMe, etc.)
# VITE_FUNCTIONS_URL=https://us-central1-your_project.cloudfunctions.net
# Local emulator: http://127.0.0.1:5001/your_project_id/us-central1

# OpenRouter API key for Chat AI (DeepSeek). No Firebase Blaze plan needed.
# Get a key at https://openrouter.ai/keys — you can restrict it by origin.
# VITE_OPENROUTER_API_KEY=sk-or-v1-...

# Self-hosted Whisper (Python logic service) for voice-to-text.
# If set, the app will call this directly and voice transcription won't rely on Firebase Functions.
# VITE_LOGIC_URL=https://your-logic-host
# Optional protection (must match LOGIC_API_KEY set on your logic server).
# VITE_LOGIC_API_KEY=some-shared-secret
