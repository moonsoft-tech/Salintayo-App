{
  "name": "salintayo-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for SalinTayo - server-side auth verification and logic",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "typescript": "^5.0.0"
  },
  "private": true
}
