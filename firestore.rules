rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * Admin: Firebase Auth custom claim admin==true, OR known admin emails.
     * Add your admin emails here after deploy. Local-only admin login (no Firebase user)
     * cannot read/write Firestore — sign in with Email/Password in the admin panel.
     */
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'admin@salintayo.com'
      );
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    /** Learner profiles — salintayo-app writes users/{uid} for the signed-in uid */
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update, delete: if isOwner(userId) || isAdmin();

      /** Quiz attempt history synced from the learner app */
      match /quizHistory/{quizId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      /** AI chat threads + messages (client SDK only; no Cloud Functions required) */
      match /chats/{chatId} {
        allow read, write: if isOwner(userId) || isAdmin();
        match /messages/{messageId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }
    }

    /** Curated dialect list for the learner app (admin-managed; app can add read rule as needed) */
    match /dialects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * Chat summaries: learners sync their own sessions from the app; admins can read/delete all.
     */
    match /chatSessions/{sessionId} {
      allow read: if isAdmin() || (
        request.auth != null &&
        resource.data.userId == request.auth.uid
      );
      allow create: if isAdmin() || (
        request.auth != null &&
        request.resource.data.userId == request.auth.uid
      );
      allow update: if isAdmin() || (
        request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid
      );
      allow delete: if isAdmin() || (
        request.auth != null &&
        resource.data.userId == request.auth.uid
      );
    }

    /** Optional aggregates doc for dashboards */
    match /adminAnalytics/{docId} {
      allow read, write: if isAdmin();
    }

    /** Admin audit trail (append from admin panel) */
    match /adminActivity/{docId} {
      allow read, write: if isAdmin();
    }

    match /passwordResetCodes/{docId} {
      allow read, write: if false;
    }

    /**
     * Bug reports from the learner app — auto doc id; learners may create many per account.
     */
    match /bugReports/{reportId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.bugType is string
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 8000;
      allow update, delete: if isAdmin();
    }

    /**
     * App rating / feedback — auto doc id; learners may submit many times.
     */
    match /appFeedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 8000;
      allow update, delete: if isAdmin();
    }
  }
}
